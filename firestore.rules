rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is timestamp;
    }

    // --- Transaction Validation ---
    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'category', 'date', 'createdAt', 'updatedAt']) &&
             data.keys().size() >= 7 &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.category is string &&
             data.category.size() <= 100 &&
             data.date is timestamp &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // --- Collection Routes ---

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );
    }

    // Transactions
    match /users/{userId}/transactions/{transactionId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isValidId(transactionId) && 
                      isValidTransaction(incoming());
      allow update: if isOwner(userId) && 
                      isValidId(transactionId) && 
                      isValidTransaction(incoming()) && (
                        incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'type', 'category', 'description', 'date', 'updatedAt'])
                      );
      allow delete: if isOwner(userId);
    }
  }
}
